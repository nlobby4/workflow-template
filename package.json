{
  "name": "@nlobby4/workflow-template",
  "version": "1.0.0",
  "private": true,
  "description": "nlobby4 workflow template",
  "type": "module",
  "scripts": {
    "audit": "npm audit --omit=dev --audit-level=high",
    "audit:dev": "npm audit --only=dev --audit-level=high",
    "build": "echo \"No build script specified\" && exit 0",
    "check": "npm run format:check && npm run lint && npm run deps:unused && npm run audit",
    "commit": "git-cz",
    "deps:check": "npm outdated",
    "deps:unused": "knip",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "lint": "npm run lint:commits && npm run lint:md && npm run lint:spell",
    "lint:commits": "commitlint --last --verbose",
    "lint:md": "markdownlint \"**/*.md\"",
    "lint:md:fix": "markdownlint \"**/*.md\" --fix",
    "lint:spell": "cspell lint \"**/*\" --dot --no-progress --no-must-find-files --cache --cache-strategy content",
    "prepare": "husky",
    "test": "echo \"No tests specified\" && exit 0"
  },
  "lint-staged": {
    "*.md": [
      "prettier --write",
      "markdownlint --fix",
      "cspell lint --no-progress --no-must-find-files"
    ],
    "*.{js,json,yaml,yml,sh}": [
      "prettier --write",
      "cspell lint --no-progress --no-must-find-files"
    ]
  },
  "config": {
    "commitizen": {
      "path": "@commitlint/cz-commitlint"
    }
  },
  "devDependencies": {
    "@commitlint/cli": "20.5.0",
    "@commitlint/config-conventional": "20.5.0",
    "@commitlint/cz-commitlint": "20.5.1",
    "@commitlint/format": "20.5.0",
    "@commitlint/types": "20.5.0",
    "commitizen": "4.3.1",
    "cspell": "10.0.0",
    "husky": "9.1.7",
    "inquirer": "9.3.8",
    "knip": "6.14.1",
    "lint-staged": "16.4.0",
    "markdownlint-cli": "0.48.0",
    "prettier": "3.8.3",
    "prettier-plugin-jsdoc": "1.8.0",
    "prettier-plugin-multiline-arrays": "4.1.8",
    "prettier-plugin-organize-imports": "4.3.0",
    "prettier-plugin-packagejson": "3.0.2",
    "prettier-plugin-sh": "0.18.1",
    "prettier-plugin-sort-json": "4.2.0",
    "prettier-plugin-yaml": "1.1.3"
  },
  "engines": {
    "node": ">=24.14.1",
    "npm": ">=11"
  }
}
