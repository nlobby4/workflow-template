# --------------------------------------------------
# Generic ignore list for prettier formatting.
#
# This file lists files and patterns that should
# not be formatted by Prettier.
#
# The Prettier vscode extension cannot use a .gitignore and .prettierignore
# at the same time, instead sync this file with .gitignore to maintain flexibility.
#
# For more information, see:
# https://github.com/prettier/prettier-vscode/issues/3894
# --------------------------------------------------

# OS-generated files
.DS_Store
.DS_Store?
Thumbs.db
Desktop.ini
$RECYCLE.BIN/
.Spotlight-V100/
.Trashes/
._*
.AppleDouble/

