# --------------------------------------------------
# Generic git ignore list.
#
# This file lists files and patterns that should
# not be tracked by git.
#
# By extension this file is used to exclude files from
# tooling and other processes that rely on git to determine
# which files are part of the project.
#
# Add your project-specific settings at the end of this file.
# --------------------------------------------------

# OS-generated files
.DS_Store
.DS_Store?
Thumbs.db
Desktop.ini
$RECYCLE.BIN/
.Spotlight-V100/
.Trashes/
._*
.AppleDouble/

# IDE & editor files
.vscode-test/
.idea/
.fleet/
.zed/
.vs/
.project
.classpath
.settings/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sln.docstates
*.user
*.userosscache
*.iml
*.sw?
*.swp
*.swo
*~
.#*
.netrwhist
.nvimlog
.emacs.desktop
.emacs.desktop.lock
*.sublime-project
*.sublime-workspace
*.code-search
*.code-search-index
*.code-search-cache
*.code-search-cache-*
*.code-search-index-*

# Environment & secrets
.env
.env.*
!.env.example
*.local
*.secret
*.key
*.pem
*.crt
*.pfx
*.p12
secrets/
credentials/

# Logs & runtime files
*.log
*.log.*
*.out
logs/
*.pid
*.seed
*.pid.lock
*.err
*.stackdump
.cache/

# Miscellaneous
*.bak
*.tmp
*.temp
*.orig
*.rej
*.sav

# Project rules
node_modules/
dist/
# TODO: Add project-specific ignore rules
