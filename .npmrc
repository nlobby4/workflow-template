# --------------------------------------------------
# NPM configuration file.
#
# This file contains settings for npm behavior, including package installation,
# publishing, and CLI output. It is designed to enforce strict versioning and
# provide a clean output in CI environments.
#
# For more information please see:
# https://docs.npmjs.com/cli/v11/configuring-npm/npmrc
# --------------------------------------------------

# Use strict semver by default
# Always install exact versions to prevent unexpected upgrades
save-exact=true

# Package publishing
registry=https://registry.npmjs.org/

# Disables npm funding messages
fund=false

# Enforce node & npm versions defined in package.json engines field
engine-strict=true

# Cache & performance
# Retry failed fetches 3 times
fetch-retries=3
# Exponential backoff factor (10s, 20s, 40s)
fetch-retry-factor=2
# Minimum timeout between retries (10 seconds)
fetch-retry-mintimeout=10000
# Maximum timeout between retries (60 seconds)
fetch-retry-maxtimeout=60000

# Hide install progress for cleaner logs
progress=false
