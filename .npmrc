# --------------------------------------------------
# NPM configuration file.
#
# This file contains settings for npm behavior, including package installation,
# publishing, and CLI output. It is designed to enforce strict versioning and
# provide a clean output in CI environments.
#
# For more information please see:
# https://docs.npmjs.com/cli/v11/configuring-npm/npmrc
# --------------------------------------------------

# Use strict semver by default
save-exact=true # always install exact versions to prevent unexpected upgrades

# Package publishing
registry=https://registry.npmjs.org/
fund=false # disables npm funding messages

# Node & package manager behavior
engine-strict=true # enforce node & npm versions in package.json
package-lock=true  # generate package-lock.json for reproducible installs

# Cache & performance
prefer-offline=false         # always fetch from network
progress=false               # hide install progress for cleaner logs
fetch-retries=3              # retry failed fetches 3 times
fetch-retry-factor=2         # exponential backoff factor (10s, 20s, 40s)
fetch-retry-mintimeout=10000 # minimum timeout between retries (10 seconds)
fetch-retry-maxtimeout=60000 # maximum timeout between retries (60 seconds)

# CLI & output
color=false    # disable color to prevent escape codes in CI logs
loglevel=error # show errors only
